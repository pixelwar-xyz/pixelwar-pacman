# Fund this wallet with USDC (Base/Arbitrum/Polygon) — no ETH needed,
# x402 payments are signed USDC transfers (the facilitator pays gas).
# Generate your own: node -e "const{generatePrivateKey,privateKeyToAccount}=require('viem/accounts');const pk=generatePrivateKey();console.log(pk, privateKeyToAccount(pk).address)"
PIXELWAR_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
